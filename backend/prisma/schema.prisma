datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  
}

// 1. Usuarios del sistema
model Usuario {
  id_usuario            Int                   @id @default(autoincrement())
  nombre                String  
  apellido              String  
  edad                  Int     
  direccion             String  
  telefono              String  
  enfermedades          String? 
  medicamentos          String? 
  ocupacion             String  
  tratamientosAsignados TratamientoAsignado[] 

  @@map("usuarios")
}

// 2. Servicios generales o Categorías
model Servicio {
  id_servicio   Int           @id @default(autoincrement())
  tipo_servicio String
  descripcion   String
  tratamientos  Tratamiento[]

  @@map("servicios")
}

// 3. Tratamientos específicos de un Servicio
model Tratamiento {
  cod_tratamiento       Int                   @id @default(autoincrement())
  costo                 Int
  descripcion           String
  id_servicio           Int
  servicio              Servicio              @relation(fields: [id_servicio], references: [id_servicio])
  tratamientosAsignados TratamientoAsignado[]

  @@map("tratamientos")
}

// 4. Tabla intermedia (Asignación de tratamiento a un Usuario)
model TratamientoAsignado {
  id_asignacion    Int      @id @default(autoincrement())
  fecha_asignacion DateTime @db.Date
  estado_actual    String   
  observaciones    String?  
  id_usuario       Int
  cod_treatment    Int      @map("cod_tratamiento") // Mapeo del campo físico

  usuario          Usuario     @relation(fields: [id_usuario], references: [id_usuario])
  tratamiento      Tratamiento @relation(fields: [cod_treatment], references: [cod_tratamiento])
  reservas         Reserva[]

  @@map("tratamientos_asignados")
}

// 5. Reservas de citas asociadas a la asignación
model Reserva {
  cod_reserva     Int                 @id @default(autoincrement())
  dia             DateTime            @db.Date
  hora            DateTime            @db.Time(0)
  tiempo_estimado DateTime            @db.Time(0)
  id_asignacion   Int
  
  asignacion      TratamientoAsignado @relation(fields: [id_asignacion], references: [id_asignacion])

  @@map("reservas")
}