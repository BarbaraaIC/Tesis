generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id_usuario               Int                   @id @default(autoincrement())
  rut                      String                @unique
  nombre                   String
  apellido                 String
  edad                     Int
  direccion                String
  telefono                 String
  correo                   String                @unique
  password                 String
  rol                      String                @default("paciente")
  enfermedades             String?
  medicamentos             String?
  ocupacion                String
  tratamientosAsignados    TratamientoAsignado[] @relation("PacienteTratamientos")
  tratamientosAsignadosPor TratamientoAsignado[] @relation("ProfesionalTratamientos")

  @@map("usuarios")
}

model Servicio {
  id_servicio   Int           @id @default(autoincrement())
  tipo_servicio String
  descripcion   String
  tratamientos  Tratamiento[]

  @@map("servicios")
}

model Tratamiento {
  cod_tratamiento       Int                   @id @default(autoincrement())
  costo                 Int
  descripcion           String
  id_servicio           Int
  servicio              Servicio              @relation(fields: [id_servicio], references: [id_servicio])
  tratamientosAsignados TratamientoAsignado[]

  @@map("tratamientos")
}

model TratamientoAsignado {
  id_asignacion    Int         @id @default(autoincrement())
  fecha_asignacion DateTime    @db.Date
  estado_actual    String
  observaciones    String?
  id_usuario       Int
  id_profesional   Int
  cod_tratamiento    Int         @map("cod_tratamiento")
  reservas         Reserva[]
  tratamiento      Tratamiento @relation(fields: [cod_tratamiento], references: [cod_tratamiento])
  usuario          Usuario     @relation("PacienteTratamientos", fields: [id_usuario], references: [id_usuario])
  profesional      Usuario     @relation("ProfesionalTratamientos", fields: [id_profesional], references: [id_usuario])

  @@map("tratamientos_asignados")
}

model Reserva {
  cod_reserva     Int                 @id @default(autoincrement())
  dia             DateTime            @db.Date
  hora            DateTime            @db.Time(0)
  tiempo_estimado DateTime            @db.Time(0)
  id_asignacion   Int
  asignacion      TratamientoAsignado @relation(fields: [id_asignacion], references: [id_asignacion])

  @@map("reservas")
}
